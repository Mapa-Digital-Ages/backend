@BaseUrl = http://localhost:8000

### Login as superadmin (run this first to get the token)
# @name adminLogin
POST {{BaseUrl}}/login
Content-Type: application/json

{
    "email": "admin@admin.com",
    "password": "admin123"
}


### List all users
GET {{BaseUrl}}/admin/users
Authorization: Bearer {{adminLogin.response.body.token}}

### List users filtered by status (aguardando, negado, aprovado)
GET {{BaseUrl}}/admin/users?user_status=aguardando
Authorization: Bearer {{adminLogin.response.body.token}}

### List users filtered by role (responsavel, aluno, admin)
GET {{BaseUrl}}/admin/users?role=responsavel
Authorization: Bearer {{adminLogin.response.body.token}}

### Register a user to approve (capture id from response)
# @name registerApproveUser
POST {{BaseUrl}}/register/responsavel
Content-Type: application/json

{
    "email": "user12@example.com",
    "password": "validpass123",
    "name": "User Approve"
}

### Approve user
PATCH {{BaseUrl}}/admin/users/{{registerApproveUser.response.body.id}}/status
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.token}}

{
    "status": "aprovado"
}

### Register a user to deny (capture id from response)
# @name registerDenyUser
POST {{BaseUrl}}/register/responsavel
Content-Type: application/json

{
    "email": "user123@example.com",
    "password": "validpass123",
    "name": "User Deny"
}

### Deny user
PATCH {{BaseUrl}}/admin/users/{{registerDenyUser.response.body.id}}/status
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.token}}

{
    "status": "negado"
}
