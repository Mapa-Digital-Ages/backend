@BaseUrl = http://localhost:8000
@ApproveGuardianEmail = teste.approve@example.com
@DenyGuardianEmail = teste.deny@example.com

### Login as superadmin (run this first to get the token)
# @name adminLogin
POST {{BaseUrl}}/login
Content-Type: application/json

{
    "email": "admin@admin.com",
    "password": "admin123"
}


### List all users
GET {{BaseUrl}}/admin/users
Authorization: Bearer {{adminLogin.response.body.token}}

### List users filtered by status (waiting, rejected, approved)
GET {{BaseUrl}}/admin/users?user_status=waiting
Authorization: Bearer {{adminLogin.response.body.token}}

### List users filtered by role (guardian, student, admin)
GET {{BaseUrl}}/admin/users?role=guardian
Authorization: Bearer {{adminLogin.response.body.token}}

### Register a guardian to approve
### If this returns 409, change @ApproveGuardianEmail before running the PATCH below.
# @name registerApproveUser
POST {{BaseUrl}}/register/guardian
Content-Type: application/json

{
  "first_name": "Guilherme",
  "last_name": "Vieira",
  "email": "{{ApproveGuardianEmail}}",
  "password": "12345678"
}

### Approve user
### Run the named POST request above first so {{registerApproveUser.response.body.id}} resolves to a UUID.
PATCH {{BaseUrl}}/admin/users/{6adebc70-366c-4021-bd11-c15ce4190f3c}/status
Authorization: Bearer {{adminLogin.response.body.token}}
Content-Type: application/json

{
  "status": "approved"
}

### Register a guardian to reject
### If this returns 409, change @DenyGuardianEmail before running the PATCH below.
# @name registerDenyUser
POST {{BaseUrl}}/register/guardian
Content-Type: application/json

{
  "first_name": "User",
  "last_name": "Deny",
  "email": "{{DenyGuardianEmail}}",
  "password": "validpass123"
}

### Deny user
PATCH {{BaseUrl}}/admin/users/{{registerDenyUser.response.body.id}}/status
Authorization: Bearer {{adminLogin.response.body.token}}
Content-Type: application/json

{
  "status": "rejected"
}
